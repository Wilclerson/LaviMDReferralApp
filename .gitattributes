# Normalize line endings to LF in the repo; check out native on Windows.
* text=auto eol=lf

# Lockfiles and generated artifacts are treated as text with LF.
pnpm-lock.yaml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.md text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
