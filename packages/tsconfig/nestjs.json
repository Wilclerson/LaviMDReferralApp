{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "LaviMD NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // Nest resolves constructor dependencies from `design:paramtypes`, which
    // requires injected classes to be *value* imports. verbatimModuleSyntax
    // would force `import type` and erase that metadata.
    "verbatimModuleSyntax": false,
    "declaration": false,
    "declarationMap": false,
    "types": ["node"]
  }
}
