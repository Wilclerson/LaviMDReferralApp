{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "db:generate": {
      "cache": false,
      "inputs": ["prisma/schema.prisma"]
    },
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "db:generate"]
    },
    "test": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^build", "db:generate"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["db:generate"]
    },
    "clean": {
      "cache": false
    }
  }
}
