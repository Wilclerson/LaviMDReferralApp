# Copy to .env and fill in real values. NEVER commit a real .env file.

# PostgreSQL connection string
DATABASE_URL="postgresql://lavimd:lavimd@localhost:5432/lavimd?schema=public"

# HTTP
PORT=3000
NODE_ENV=development

# Auth — generate a strong random secret (e.g. `openssl rand -base64 48`)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="1h"

# Seed credentials (development only; the seed refuses to run in production)
SEED_SUPER_ADMIN_EMAIL="superadmin@example.com"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"
